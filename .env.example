# FinGuard Deployment Freezer local environment example
# Copy this file to .env only for local use.
# Never commit real .env files.

APP_ENV=local

PAYMENT_API_PORT=8000
FREEZER_CONTROLLER_PORT=8010

POSTGRES_DB=finguard
POSTGRES_USER=finguard_user
POSTGRES_PASSWORD=change-me-local-only
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# SLO / error budget defaults
SLO_AVAILABILITY_TARGET=99.9
ERROR_BUDGET_WINDOW_MINUTES=60
MAX_ERROR_RATE_PERCENT=1
MAX_P95_LATENCY_MS=500
